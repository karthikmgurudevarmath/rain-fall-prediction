   "source": [
    "from xgboost import XGBClassifier\n",
    "\n",
    "xgb = XGBClassifier()\n",
    "\n",
    "xgb.fit(X_train, y_train)\n",
    "\n",
    "train_pred = xgb.predict(X_train)\n",
    "test_pred = xgb.predict(X_test)\n",
    "\n",
    "print(\"XGBoost Training Accuracy:\",\n",
    "      accuracy_score(y_train, train_pred))\n",
    "\n",
