    "# Predict rainfall using trained model (example: XGBoost)\n",
    "predictions = xgb.predict(X_test)\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "# Count YES (1) and NO (0)\n",
    "yes_count = np.sum(predictions == 1)\n",
    "no_count = np.sum(predictions == 0)\n",
    "\n",
    "total = len(predictions)\n",
    "\n",
    "yes_percent = (yes_count / total) * 100\n",
    "no_percent = (no_count / total) * 100\n",
    "\n",
    "print(\"Rainfall YES: {:.2f}%\".format(yes_percent))\n",
    "print(\"Rainfall NO: {:.2f}%\".format(no_percent))"
